{% extends 'base.html.twig' %}

{% block body_class %}min-h-screen{% endblock %}

{% block body %}
<div
    class="flex flex-col h-screen max-h-screen"
    data-controller="recipe-chat"
    data-recipe-chat-url-value="{{ path('admin_recipe_chat_message') }}"
>
    {# Header #}
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-700 bg-slate-900/80 backdrop-blur">
        <div class="flex items-center gap-3">
            <a href="{{ path('admin') }}" class="text-slate-400 hover:text-amber-400 transition-colors" title="Retour à l'admin">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </a>
            <div>
                <h1 class="text-white font-semibold text-lg leading-tight">Assistant Recettes</h1>
                <p class="text-slate-500 text-xs">Propulsé par Cookbook API</p>
            </div>
        </div>
        <button
            data-action="recipe-chat#reset"
            class="text-xs text-slate-400 hover:text-amber-400 transition-colors flex items-center gap-1.5 border border-slate-700 hover:border-amber-400/50 rounded-lg px-3 py-1.5"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Nouvelle conversation
        </button>
    </div>

    {# Messages #}
    <div
        class="flex-1 overflow-y-auto px-4 py-6 space-y-4"
        data-recipe-chat-target="messages"
    >
        {# Message de bienvenue #}
        <div class="flex gap-3 justify-start">
            <div class="w-8 h-8 rounded-full bg-amber-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
            </div>
            <div class="max-w-2xl">
                <div class="bg-slate-800 border border-slate-700 rounded-2xl rounded-tl-sm px-4 py-3 text-slate-300 text-sm leading-relaxed">
                    Bonjour ! Je suis votre assistant culinaire. Dites-moi ce dont vous avez envie — un type de plat, des ingrédients disponibles, un régime alimentaire — et je vous proposerai une recette sur mesure.
                </div>
            </div>
        </div>
    </div>

    {# Input #}
    <div class="border-t border-slate-700 bg-slate-900/80 backdrop-blur px-4 py-4">
        <form
            data-action="submit->recipe-chat#submit"
            class="flex gap-2 items-end max-w-4xl mx-auto"
        >
            <textarea
                data-recipe-chat-target="input"
                placeholder="Demandez une recette…"
                rows="1"
                class="flex-1 bg-slate-800 border border-slate-600 focus:border-amber-500 rounded-xl px-4 py-3 text-slate-200 placeholder-slate-500 text-sm resize-none outline-none transition-colors"
                data-action="keydown.enter->recipe-chat#submitOnEnter"
            ></textarea>
            <button
                type="submit"
                data-recipe-chat-target="submit"
                class="bg-amber-500 hover:bg-amber-400 disabled:bg-slate-700 disabled:text-slate-500 text-slate-900 font-medium rounded-xl px-4 py-3 text-sm transition-colors flex items-center gap-2 flex-shrink-0"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                Envoyer
            </button>
        </form>
        <p class="text-center text-slate-600 text-xs mt-2 max-w-4xl mx-auto">
            Propulsé par Cookbook API
        </p>
    </div>
</div>
{% endblock %}
