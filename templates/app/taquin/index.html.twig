{# templates/app/taquin/index.html.twig #}
{% extends 'base.html.twig' %}
{% block body_class %}overflow-hidden{% endblock %}

{% block body %}
<div class="flex justify-center items-start md:items-center min-h-screen pt-16 md:-pt-2">
    <div data-controller="taquin"
        class="flex flex-col items-center gap-6 bg-slate-800 p-8 rounded-2xl shadow-2xl w-fit">

        <div data-taquin-target="grid">
            <h1
                class="text-white text-2xl font-bold tracking-wide mb-4 text-center flex items-center gap-2 justify-center">
                <span class="w-7 h-7">{{ include('components/_icon_taquin.html.twig') }}</span>
                Taquin
                <div class="relative group">
                    <span class="text-slate-400 hover:text-white cursor-help text-base">ⓘ</span>
                    <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-opacity
                    absolute left-1/2 -translate-x-1/2 top-full mt-2 w-64
                    bg-slate-700 text-slate-300 text-sm font-normal rounded-lg p-3 shadow-xl z-10">
                        <p class="mt-1">L'objectif est de remettre les tuiles dans l'ordre en les déplaçant une par une
                            via la case vide.
                        </p>
                    </div>
                </div>
            </h1>
            <div class="grid grid-cols-4 gap-2" data-action="click->taquin#move">
                {% for i in 1..15 %}
                <div class="tile">
                    {{ i }}
                </div>
                {% endfor %}
                <div class="empty w-16 h-16 bg-slate-700 rounded-lg"></div>
            </div>
        </div>
        <div class="grid">
            <div class="grid grid-cols-2 gap-2">
                <a href="{{ path('homepage') }}"
                    class="bg-slate-600 hover:bg-slate-700 text-white font-bold px-6 py-2 rounded-full transition-colors cursor-pointer text-center">
                    Retour
                </a>
                <button data-action="click->taquin#shuffle"
                    class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-6 py-2 rounded-full transition-colors cursor-pointer">
                    Mélanger
                </button>

            </div>
        </div>

        <div data-taquin-target="winOverlay"
            class="hidden absolute inset-0 bg-slate-900/90 backdrop-blur-sm rounded-2xl flex flex-col items-center justify-center gap-4">
            <p class="text-5xl">🎉</p>
            <p class="text-white text-2xl font-bold tracking-wide">Bravo !</p>
            <button data-action="click->taquin#replay"
                class="px-6 py-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-full transition-colors cursor-pointer">
                Rejouer
            </button>
        </div>
    </div>

</div>

{{ include('components/_app_detail_drawer.html.twig') }}
{% endblock %}