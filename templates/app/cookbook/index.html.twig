{# templates/app/cookbook/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Cookbook{% endblock %}

{% block body %}
<div class="min-h-screen py-10 px-4">
    <div class="max-w-4xl mx-auto flex flex-col gap-6">

        {# Header #}
        <div class="flex items-center gap-3">
            <span class="w-7 h-7 text-amber-400">{{ include('components/_icon_cookbook.html.twig') }}</span>
            <h1 class="text-white text-2xl font-bold tracking-wide">Mon livre de recettes</h1>
        </div>

        {# Info encart #}
        <div class="bg-slate-800/60 border border-slate-700 rounded-xl px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1 flex flex-col gap-1">
                <p class="text-slate-300 text-sm leading-relaxed">
                    Cette page est connectée à mon API <span class="text-amber-400 font-medium">Cookbook</span>,
                    construite avec <span class="text-white font-medium">Symfony</span> et
                    <span class="text-white font-medium">API Platform</span>.
                    Elle expose mes recettes via une API REST sécurisée par JWT.
                </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
                <a href="https://github.com/korhy/cookbook/"
                   target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    </svg>
                    GitHub
                </a>
                <span class="text-slate-600">|</span>
                <a href="{{ apiDocUrl }}"
                   target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-amber-400 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.966 8.966 0 0 0-6 2.292m0-14.25v14.25"/>
                    </svg>
                    Documentation API
                </a>
            </div>
        </div>

        {# Back #}
        <a href="{{ path('homepage') }}"
           class="text-slate-400 hover:text-white transition-colors">
            ← Retour
        </a>

        {# Recipe cards #}
        {% if recipes is not empty %}
            <div data-controller="cookbook" data-cookbook-next-page-value="2">
            <div id="recipe-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for recipe in recipes %}
                    <a href="{{ path('cookbook_recipe', { id: recipe.id }) }}"
                       class="group bg-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-amber-500/10 hover:-translate-y-1 transition-all duration-200">

                        {# Thumbnail #}
                        {% if recipe.thumbnail %}
                            <img src="{{ recipe.thumbnail }}"
                                 alt="{{ recipe.title }}"
                                 class="w-full h-40 object-cover group-hover:brightness-110 transition-all duration-200">
                        {% else %}
                            <div class="w-full h-40 bg-slate-700 flex items-center justify-center">
                                <span class="w-10 h-10 text-slate-500">
                                    {{ include('components/_icon_cookbook.html.twig') }}
                                </span>
                            </div>
                        {% endif %}

                        <div class="p-4 flex flex-col gap-2">
                            <h2 class="text-white font-semibold text-sm leading-snug group-hover:text-amber-400 transition-colors">
                                {{ recipe.title }}
                            </h2>
                            <div class="flex items-center gap-2 flex-wrap mt-auto">
                                {% if recipe.category is defined and recipe.category %}
                                    <span class="bg-amber-500/20 text-amber-400 text-xs font-medium px-2 py-0.5 rounded-full">
                                        {{ recipe.category.name }}
                                    </span>
                                {% endif %}
                                {% if recipe.duration %}
                                    <span class="text-slate-400 text-xs flex items-center gap-1 ml-auto">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                                        </svg>
                                        {{ recipe.duration }} min
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                    </a>
                {% endfor %}
            </div>
            {% if hasNextPage %}
            <div data-cookbook-target="loadMoreContainer" class="flex justify-center mt-6">
                <span data-cookbook-target="button" class="text-slate-500 text-sm animate-pulse">
                    Chargement…
                </span>
            </div>
            {% endif %}
            </div>
        {% else %}
            <div class="bg-slate-800 rounded-2xl p-12 text-center">
                <span class="w-12 h-12 text-slate-600 mx-auto block mb-4">
                    {{ include('components/_icon_cookbook.html.twig') }}
                </span>
                <p class="text-slate-400">Aucune recette pour l'instant.</p>
            </div>
        {% endif %}

    </div>
</div>

{{ include('components/_app_detail_drawer.html.twig') }}
{% endblock %}
