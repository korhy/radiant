{# templates/app/cookbook/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Cookbook{% endblock %}

{% block body %}
<div class="min-h-screen pt-4 pb-10 sm:py-10 px-4">
    <div class="max-w-4xl mx-auto flex flex-col gap-6">
        {# Navbar #}
        {{ include('app/cookbook/navbar.html.twig') }}

        {# Breadcrumb #}
        {{ include('app/cookbook/breadcrumb.html.twig', { breadcrumbs: [
        { label: 'Portfolio', path: path('homepage') },
        { label: 'Cookbook', path: path('cookbook') },
        ]}) }}

        {# Filters & sorts #}
        <div data-controller="cookbook" data-cookbook-next-page-value="2"
            data-cookbook-categories-value="{{ categories|json_encode }}">

            <div class="flex flex-col sm:flex-row gap-3">
                <input data-cookbook-target="searchInput" type="search" placeholder="Rechercher une recette…"
                    class="flex-1 bg-slate-800 border border-slate-700 rounded-xl px-4 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-amber-500 transition-colors">

                <div class="relative">
                    <select data-cookbook-target="categorySelect"
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 pr-10 py-2 text-sm text-white focus:outline-none focus:border-amber-500 transition-colors appearance-none">
                        <option value="">Toutes les catégories</option>
                        {% for category in categories %}
                        <option value="{{ category.id }}">{{ category.name }}</option>
                        {% endfor %}
                    </select>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2"
                        stroke="currentColor" class="pointer-events-none h-4 w-4 absolute top-1/2 right-3 -translate-y-1/2 text-slate-400">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                </div>
            </div>

            <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-slate-500 text-xs self-center">Trier par :</span>
                <button data-cookbook-target="sortBtn" data-sort="title" data-action="cookbook#sort"
                    class="px-3 py-1 rounded-full text-xs border border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-400 transition-colors">
                    Titre
                </button>
                <button data-cookbook-target="sortBtn" data-sort="createdAt" data-action="cookbook#sort"
                    class="px-3 py-1 rounded-full text-xs border border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-400 transition-colors">
                    Date
                </button>
                <button data-cookbook-target="sortBtn" data-sort="duration" data-action="cookbook#sort"
                    class="px-3 py-1 rounded-full text-xs border border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-400 transition-colors">
                    Durée
                </button>
            </div>

            {# Recipe cards #}
            {% if recipes is not empty %}
            <div id="recipe-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
                {% for recipe in recipes %}
                <a href="{{ path('cookbook_recipe', { id: recipe.id }) }}"
                    class="group bg-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-amber-500/10 hover:-translate-y-1 transition-all duration-200">

                    {# Thumbnail #}
                    {% if recipe.thumbnail %}
                    <img src="{{ recipe.thumbnail }}" alt="{{ recipe.title }}"
                        class="w-full h-40 object-cover group-hover:brightness-110 transition-all duration-200">
                    {% else %}
                    <div class="w-full h-40 bg-slate-700 flex items-center justify-center">
                        <span class="w-10 h-10 text-slate-500">
                            {{ include('components/_icon_cookbook.html.twig') }}
                        </span>
                    </div>
                    {% endif %}

                    <div class="p-4 flex flex-col gap-2">
                        <h2
                            class="text-white font-semibold text-sm leading-snug group-hover:text-amber-400 transition-colors">
                            {{ recipe.title }}
                        </h2>
                        <div class="flex items-center gap-2 flex-wrap mt-auto">
                            {% if recipe.category is defined and recipe.category %}
                            <span class="bg-amber-500/20 text-amber-400 text-xs font-medium px-2 py-0.5 rounded-full">
                                {{ recipe.category.name }}
                            </span>
                            {% endif %}
                            {% if recipe.duration %}
                            <span class="text-slate-400 text-xs flex items-center gap-1 ml-auto">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="1.5"
                                    viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 6v6l4 2" />
                                </svg>
                                {{ recipe.duration }} min
                            </span>
                            {% endif %}
                        </div>
                    </div>

                </a>
                {% endfor %}
            </div>
            {% if hasNextPage %}
            <div data-cookbook-target="loadMoreContainer" class="flex justify-center mt-6">
                <span data-cookbook-target="button" class="text-slate-500 text-sm animate-pulse">
                    Chargement…
                </span>
            </div>
            {% endif %}
            {% else %}
            <div id="recipe-grid" class="bg-slate-800 rounded-2xl p-12 text-center mt-6">
                <span class="w-12 h-12 text-slate-600 mx-auto block mb-4">
                    {{ include('components/_icon_cookbook.html.twig') }}
                </span>
                <p class="text-slate-400">Aucune recette pour l'instant.</p>
            </div>
            {% endif %}

        </div>{# /data-controller #}

    </div>
</div>

{{ include('components/_app_detail_drawer.html.twig') }}
{% endblock %}